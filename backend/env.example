# MongoDB Connection
# For local MongoDB: mongodb://127.0.0.1:27017/auto-taxi-booking-app
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/auto-taxi-booking-app
MONGODB_URI=mongodb://127.0.0.1:27017/auto-taxi-booking-app

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Secret for authentication (change this to a random string in production)
JWT_SECRET=your-secret-key-change-this-in-production

# Twilio — SMS pickup OTP to passenger (E.164 FROM number, e.g. +15551234567)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Gemini — Route safety analyzer (get a key from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# Public origin used to build share URLs (the page hosting /track/:token)
APP_PUBLIC_ORIGIN=http://localhost:8080